{
  "name": "posture-core",
  "private": true,
  "version": "0.0.1",
  "description": "Webcam-based posture coach with a fairy overlay nudge",
  "author": "madcamp-official",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build --emptyOutDir false",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "electron:dev": "node electron/dev-launcher.js",
    "dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.22-rc.20250304"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "electron": "^43.1.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.20.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.24.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.madcamp.posturefairy",
    "productName": "PostureFairy",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "electron/preload.cjs",
      "package.json"
    ],
    "win": {
      "target": "zip"
    }
  }
}
